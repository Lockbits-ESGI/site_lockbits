# LockBits Docker Configuration
# Copy this file to .env and adjust values as needed

# ========================================
# Web Service (PHP Apache)
# ========================================
# Port to expose the web application on (localhost:WEB_PORT)
WEB_PORT=8080

# PHP settings (optional)
PHP_MEMORY_LIMIT=256M
PHP_UPLOAD_MAX_FILESIZE=10M
PHP_POST_MAX_SIZE=10M

# ========================================
# Database (MySQL)
# ========================================
# Database connection details
DB_HOST=db
DB_PORT=3306
DB_NAME=lockbits_client
DB_USER=lockbits
DB_PASS=lockbits_password

# MySQL root credentials (for initialization only)
DB_ROOT_PASSWORD=root_password

# Expose MySQL port on host (optional, for external tools like phpMyAdmin)
# Set to empty or comment out to not expose
DB_EXPOSE_PORT=3307

# ========================================
# Application
# ========================================
APP_NAME=LockBits Client Area
APP_ENV=development
# APP_ENV can be: development, staging, production

# Base path where the client area is hosted (examples: /client, /site_lockbits/client, empty)
APP_BASE_PATH=/site_lockbits/client

# ========================================
# GLPI (Support)
# ========================================
# Web UI base URL (without trailing slash)
GLPI_WEB_URL=https://glpi.lockbits.pro

# --- Option A: Legacy REST API (v1) ---
# Enable "Legacy REST API" in GLPI, then use:
# GLPI_API_URL=https://glpi.example.com/apirest.php
GLPI_API_URL=
# API client token (Setup > General > API > API clients)
GLPI_APP_TOKEN=
# User "Remote access key" (user token) of a service account
GLPI_USER_TOKEN=

# --- Option B: RESTful API v2 (OAuth2) ---
# GLPI_API_URL=https://glpi.example.com/api.php/v2.2
GLPI_OAUTH_CLIENT_ID=
GLPI_OAUTH_CLIENT_SECRET=
GLPI_API_USERNAME=
GLPI_API_PASSWORD=
GLPI_OAUTH_SCOPE=api user email
